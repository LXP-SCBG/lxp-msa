# init 스크립트(schema/data.sql)에 charset 선언이 없어, 서버·클라이언트 기본
# 문자셋을 utf8mb4로 고정한다. 이게 없으면 한글이 latin1로 해석돼
# VARCHAR(30) 컬럼에서 "Data too long" 에러로 초기화가 실패한다.
[mysqld]
character-set-server=utf8mb4
collation-server=utf8mb4_unicode_ci

[client]
default-character-set=utf8mb4

[mysql]
default-character-set=utf8mb4
